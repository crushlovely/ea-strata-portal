<script type="text/javascript">
    function OnAuditToolbarItemClick(s, e) {
        if (e.item.name !== "ExportFilteredToXlsx") {
            return;
        }

        e.processOnServer = false;

        var filterExpression = "";

        if (s.GetFilterExpression) {
            filterExpression = s.GetFilterExpression();
        } else if (s.cpFilterExpression) {
            filterExpression = s.cpFilterExpression;
        }

        document.getElementById("AuditFilterExpression").value = filterExpression || "";
        document.getElementById("auditExportForm").submit();
    }
</script>


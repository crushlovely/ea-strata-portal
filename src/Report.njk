<script>
    var reportAction = "/Report";

    function ShowSSNPopup(s, e, action) {
        UnderstandCheckbox.SetValue(false);
        pcAcknowledgeSSN.Show();

        reportAction = action;
    }

    function HandleReportExport(s, e) {
        if (UnderstandCheckbox.GetValue() != true) {
            alert("Please check the box to state that you understand the report contains PII.");
            return;
        }

        pcAcknowledgeSSN.Hide();

        window.location.href = reportAction;
    }
</script>


<script type="text/javascript">

    function ToggleTimeAndExpense(s, e) {
        var action = '';
        if (s.GetChecked() == false)
            action = 'disallow';
        else
            action = 'allow';

        if (confirm('Are you sure you want to toggle the Time & Expense module? This will ' + action + ' users with the appropriate permissions to access Time & Expense related functions. Continue?')) {
            $.ajax({
                cache: false,
                type: "POST",
                url: '/Case/ToggleTimeAndExpense',
                success: function(data) {
                    showFlashIfPopulated();
                },
                error: function(data) {
                    showFlashIfPopulated();
                },
                complete: function() {
                    window.location.reload();
                }
            });
        }
    }

    function ToggleTimeAndExpenseJurisdiction(s, e) {
        var action = '';
        if (s.GetChecked() == false)
            action = 'hide';
        else
            action = 'show';

        if (confirm('Are you sure you want to toggle the Time & Expense Jurisdiction field? This will ' + action + ' the jurisdiction field on Time and Expense popups. Continue?')) {
            $.ajax({
                cache: false,
                type: "POST",
                url: '/Case/ToggleTimeAndExpenseJurisdiction',
                success: function(data) {
                    showFlashIfPopulated();
                },
                error: function(data) {
                    showFlashIfPopulated();
                },
                complete: function() {
                    window.location.reload();
                }
            });
        }
    }

    function ToggleTimeAndExpenseApprovedBy(s, e) {
        var action = '';
        if (s.GetChecked() == false)
            action = 'hide';
        else
            action = 'show';

        if (confirm('Are you sure you want to toggle the Time & Expense Approved By field? This will ' + action + ' the approved by field on Time and Expense popups. Continue?')) {
            $.ajax({
                cache: false,
                type: "POST",
                url: '/Case/ToggleTimeAndExpenseApprovedBy',
                success: function(data) {
                    showFlashIfPopulated();
                },
                error: function(data) {
                    showFlashIfPopulated();
                },
                complete: function() {
                    window.location.reload();
                }
            });
        }
    }

    function ToggleTimeEntryHourlyRate(s, e) {
        var action = '';
        if (s.GetChecked() == false)
            action = 'hide';
        else
            action = 'show';

        if (confirm('Are you sure you want to toggle the Time Entry Hourly Rate and Total fields? This will ' + action + ' those fields on Time Entry popups. Continue?')) {

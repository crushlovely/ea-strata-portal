                    showFlashIfPopulated();
                },
                complete: function() {
                    window.location.reload();
                }
            });
        }
    }

    function ToggleTimeAndExpenseNameOfCaseMemo(s, e) {
        let action = '';
        if (s.GetChecked() == false)
            action = 'hide';
        else
            action = 'show';

        if (confirm('Are you sure you want to toggle the Time & Expense Name of Case Memo field? This will ' + action + ' the Name of Case Memo field on Time and Expense popups. Continue?')) {
            $.ajax({

                    showFlashIfPopulated();
                },
                error: function(data) {
                    showFlashIfPopulated();
                },
                complete: function() {
                    window.location.reload();
                }
            });
        }
    }

    function ToggleTimeAndExpenseActivityCode(s, e) {
        let action = '';
        if (s.GetChecked() == false)

                    showFlashIfPopulated();
                },
                error: function(data) {
                    showFlashIfPopulated();
                },
                complete: function() {
                    window.location.reload();
                }
            });
        }
    }

    function ToggleTimeAndExpenseExpenseType(s, e) {
        let action = '';
        if (s.GetChecked() == false)
            action = 'hide';
        else
            action = 'show';

        if (confirm('Are you sure you want to toggle the Expense Entry Expense Type field? This will ' + action + ' the Expense Type field on Expense popups. Continue?')) {
            $.ajax({
                cache: false,

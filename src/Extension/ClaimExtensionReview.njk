<div class="d-grid grid-cols-1 gap-block">



	<script type="text/javascript">
		var selectedIDs, claimNumber, extensionTypeID, extensionNumber;

		function onSelectAllClick() {
			gvExtensionReview.SelectRows();
		}
		function onClearSelectionClick() {
			gvExtensionReview.UnselectRows();
		}

		function OnGridInit(s, e) {
			s.PerformCallback()
			UpdateTitlePanel();
		}
		function OnGridSelectionChanged(s, e) {
			s.GetSelectedFieldValues("Id", GetSelectedFieldValuesCallback);
			UpdateTitlePanel();
		}
		function OnGridBeginCallback(s, e) {

		}
		function OnGridEndCallback() {
			UpdateTitlePanel();
		}
		function UpdateTitlePanel() {
			var text = "Total rows selected: <b>" + gvExtensionReview.GetSelectedRowCount() + "</b>. ";
			var hiddenSelectedRowCount = GetHiddenSelectedByFilteredRowCount();
			if (hiddenSelectedRowCount > 0)
				text += "Selected rows hidden by the applied filter: <b>" + hiddenSelectedRowCount + "</b>.";
			text += "<br />";
			lblInfo.SetText(text);

			//SetElementVisibility(lnkSelectAllRows, gvExtensionReview.cpVisibleRowCount > selectedFilteredRowCount);
			SetElementVisibility(lnkClearSelection, gvExtensionReview.GetSelectedRowCount() > 0);
			SetElementEnabled(btnExtensionPop, gvExtensionReview.GetSelectedRowCount() > 0);
		}
		function GetHiddenSelectedByFilteredRowCount() {
			return gvExtensionReview.cpSelectedRowsHiddenByFilter;
		}
		function SetElementVisibility(id, visible) {
			visible ? id.SetVisible(true) : id.SetVisible(false)
		}
		function SetElementEnabled(id, visible) {
			visible ? id.SetEnabled(true) : id.SetEnabled(false)
		}
		function GetSelectedFieldValuesCallback(values) {
			selectedIDs = values.join(',');
		}

		function OpenExtPopup() {
			deExtensionDate.SetValue(null);
			memReviewComment.SetText('');
			btnApproveExtensions.SetEnabled(true);
			btnDenyExtensions.SetEnabled(true);
			btnApproveExtensions.SetText("Approve Extension Requests");
			btnDenyExtensions.SetText("Deny Extension Requests");
			popExtensionReview.Show();
		}

		function ApproveExtensions() {
			btnApproveExtensions.SetEnabled(false);
			btnDenyExtensions.SetEnabled(false);
			btnApproveExtensions.SetText("Submitting...");
			$.ajax({
				cache: false,
				url: '/Extension/ApproveExtensions',
				type: 'POST',
				data: {
					extensionDate: deExtensionDate.GetText(),
					comment: memReviewComment.GetText(),
					selectedExtensions: selectedIDs
				},
				success: function (data) {
					showFlashIfPopulated();
					popExtensionReview.Hide();
					gvExtensionReview.UnselectRows();
					gvExtensionReview.Refresh();
				},
				error: function (data) {
					showFlashIfPopulated();
					popExtensionReview.Hide();
					gvExtensionReview.UnselectRows();
				}
			});
		}

		function DenyExtensions() {
			btnApproveExtensions.SetEnabled(false);
			btnDenyExtensions.SetEnabled(false);
			btnDenyExtensions.SetText("Submitting...");
			$.ajax({
				cache: false,
				url: '/Extension/DenyExtensions',
				type: 'POST',
				data: {
					comment: memReviewComment.GetText(),
					selectedExtensions: selectedIDs
				},
				success: function (data) {
					showFlashIfPopulated();
					popExtensionReview.Hide();
					gvExtensionReview.UnselectRows();
				},
				error: function (data) {
					showFlashIfPopulated();
					popExtensionReview.Hide();
					gvExtensionReview.UnselectRows();
				}
			});
		}

		function tabChanged(s, e) {
			var tabName = e.tab.GetText();
			if (tabName == "Unreviewed") {
				if (!gvExtensionReview.InCallback()) {
					gvExtensionReview.PerformCallback();
				}
			}
			else if (tabName == "Approved") {
				if (!gvExtensionReviewApproved.InCallback()) {
					gvExtensionReviewApproved.PerformCallback();
				}
			}
			else if (tabName == "Denied") {
				if (!gvExtensionReviewDenied.InCallback()) {
					gvExtensionReviewDenied.PerformCallback();
				}
			}
		}

		function getExtensionInfo(s, e, claimNum, extID, extNum) {
			claimNumber = claimNum;
			extensionTypeID = extID
			extensionNumber = extNum;
			pcExtensionRequestHistory.PerformCallback();
			pcExtensionRequestHistory.Show();
		}

		function RequestHistoryBeginCallback(s, e) {
			e.customArgs["claimNumber"] = claimNumber;
			e.customArgs["extensionTypeID"] = extensionTypeID;
			e.customArgs["extensionNumber"] = extensionNumber;
		}
		function RequestHistoryEndCallback(s, e) {
			claimNumber = null;
			extensionTypeID = null;
			extensionNumber = null;
		}
	</script>


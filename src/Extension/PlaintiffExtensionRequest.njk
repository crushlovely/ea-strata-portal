<div class="d-grid grid-cols-1 gap-block">



	<script type="text/javascript">
		var selectedIDs, selectedRecords, plaintiffNumber, extensionTypeID, extensionNumber;
		var isCMOValid = false;
		var selectedIndex = null;
		var searchIds = null;
		var searchType = null;
		var selectedFieldValuesPromise = Promise.resolve();

		function onSelectAllClick() {
			var filterExpression = gvExtensions.cpFilterExpression || "";
			$.ajax({
				url: '/Extension/GetPlaintiffExtensionFilteredIds',
				type: 'POST',
				data: { filterExpression: filterExpression, searchType: searchType, searchIds: searchIds },
				traditional: true,
				success: function (ids) {
					gvExtensions.SelectRowsByKey(ids);
				}
			});
		}
		function onClearSelectionClick() {
			gvExtensions.UnselectRows();
		}

		function OnGridInit(s, e) {
			s.PerformCallback()
			UpdateTitlePanel();
		}
		function OnGridSelectionChanged(s, e) {
			UpdateTitlePanel();
		}
		function OnGridBeginCallback(s, e) {

			let plaintiffIdSearchTypeValue = 0;
			let ticketSearchTypeValue = 1;
			let lawFirmIdSearchTypeValue = 2;
			const searchTypeValues = [plaintiffIdSearchTypeValue, ticketSearchTypeValue, lawFirmIdSearchTypeValue];

			e.customArgs["searchType"] = searchType;

			if (searchTypeValues.includes(searchType)) {
				e.customArgs["searchIds"] = searchIds;
			}

			return;
		}
		function OnGridEndCallback() {
			UpdateTitlePanel();
		}
		function UpdateTitlePanel() {
			var text = "Total rows selected: <b>" + gvExtensions.GetSelectedRowCount() + "</b>. ";
			var hiddenSelectedRowCount = GetHiddenSelectedByFilteredRowCount();
			if (hiddenSelectedRowCount > 0)
				text += "Selected rows hidden by the applied filter: <b>" + hiddenSelectedRowCount + "</b>.";
			text += "<br />";
			lblInfo.SetText(text);

			//SetElementVisibility(lnkSelectAllRows, gvExtensions.cpVisibleRowCount > selectedFilteredRowCount);
			SetElementVisibility(lnkClearSelection, gvExtensions.GetSelectedRowCount() > 0);
			SetElementEnabled(btnExtensionPop, gvExtensions.GetSelectedRowCount() > 0);
		}
		function GetHiddenSelectedByFilteredRowCount() {
			return gvExtensions.cpSelectedRowsHiddenByFilter;
		}
		function SetElementVisibility(id, visible) {
			visible ? id.SetVisible(true) : id.SetVisible(false)
		}
		function SetElementEnabled(id, visible) {
			visible ? id.SetEnabled(true) : id.SetEnabled(false)
		}

		async function OpenExtPopup() {
			var grid = gvExtensions
			var button = btnExtensionPop;

			btnExtensionPop.SetEnabled(false);
			lpGrid.Show();

			selectedFieldValuesPromise = new Promise(resolve => {
				grid.GetSelectedFieldValues("AssociatedClaimId", function (ids) {
					selectedIDs = ids.join(',');
					$.ajax({
						url: '/Extension/GetSelectedExtensionData',
						type: 'POST',
						data: { selectedIds: ids },
						success: function (data) {
							selectedRecords = data.map(sr => {
								return {
									Id: sr.AssociatedClaimId,
									HasPFSActiveExtension: sr.HasPFSActiveExtension,
									HasCMO37ActiveExtension: sr.HasCMO37ActiveExtension,
									DeficiencyTicketSummary: sr.DeficiencyTicketSummary,
									IsPFSPlaintiff: sr.IsPFSPlaintiff
								};
							});
							resolve();
						}
					});
				});
			});
			await selectedFieldValuesPromise;

			isCMOValid = selectedRecords.every(p => p.DeficiencyTicketSummary != null && p.DeficiencyTicketSummary.trim() !== '');
			popExtensionRequest.PerformCallback();
		}

		function ExtensionRequestPopupBeginCallback(s, e) {
			e.customArgs["isCMOValid"] = isCMOValid
		}
		function ExtensionRequestPopupEndCallback(s, e) {
			lpGrid.Hide();
			btnExtensionPop.SetEnabled(true);
			s.Show();
		}

		function SaveExtensions() {
			btnSaveExtensions.SetEnabled(false);
			lblExtensionError.SetVisible(false);
			var isPFSExtensionAndHasExension = selectedRecords.some(p => p.HasPFSActiveExtension && rblExtensionTypes.GetValue() == 3);
			var isCMO37ExtensionAndHasExension = selectedRecords.some(p => p.HasCMO37ActiveExtension && rblExtensionTypes.GetValue() == 4);
			var isPPFAndPlaitniffExtension = selectedRecords.some(p => !p.IsPFSPlaintiff && rblExtensionTypes.GetValue() == 3);

			if (isPFSExtensionAndHasExension || isCMO37ExtensionAndHasExension) {
				btnSaveExtensions.SetEnabled(true);
				lblExtensionError.SetText('At least one selected plaintiff has an active extension request.');
				lblExtensionError.SetVisible(true);
				return;
			}

			if (isPPFAndPlaitniffExtension) {
				btnSaveExtensions.SetEnabled(true);
				lblExtensionError.SetText('At least one selected plaintiff is a PPF. PFS Submission Extension is not a valid extension option for PPFs.');
				lblExtensionError.SetVisible(true);
				return;
			}

			btnSaveExtensions.SetText("Submitting...");
			$.ajax({
				cache: false,
				url: '/Extension/SaveExtensions',
				type: 'POST',
				data: {
					extensionTypeId: rblExtensionTypes.GetValue(),
					reason: memReason.GetText(),
					selectedClaims: selectedIDs
				},
				success: function (data) {
					showFlashIfPopulated();
					popExtensionRequest.Hide();
					gvExtensions.UnselectRows();
				},
				error: function (data) {
					showFlashIfPopulated();
					popExtensionRequest.Hide();
					gvExtensions.UnselectRows();
				}
			});
		}

		function tabChanged(s, e) {
			var tabName = e.tab.GetText();
			if (tabName == "Plaintiffs") {
				if (!gvExtensions.InCallback()) {
					gvExtensions.PerformCallback();
				}
			}
			else if (tabName == "Not Yet Reviewed") {
				if (!gvExtensionRequestNotReviewed.InCallback()) {
					gvExtensionRequestNotReviewed.PerformCallback();
				}
			}
			else if (tabName == "Reviewed") {
				if (!gvExtensionRequestReviewed.InCallback()) {
					gvExtensionRequestReviewed.PerformCallback();
				}
			}
		}

		function getExtensionInfo(s, e, claimNum, extID, extNum) {
			plaintiffNumber = claimNum;
			extensionTypeID = extID
			extensionNumber = extNum
			pcExtensionRequestHistory.PerformCallback();
			pcExtensionRequestHistory.Show();
		}

		function RequestHistoryBeginCallback(s, e) {
			e.customArgs["claimNumber"] = plaintiffNumber;
			e.customArgs["extensionTypeID"] = extensionTypeID;
			e.customArgs["extensionNumber"] = extensionNumber;
		}

		function RequestHistoryEndCallback(s, e) {
			plaintiffNumber = null;
			extensionTypeID = null;
			extensionNumber = null;
		}

		function GetGridBasedOnCurrentTab() {
			let currentTab = TabControl.GetActiveTab().GetText();
			if (currentTab === "Plaintiffs") {
				return gvExtensions;
			}
			else if (currentTab === "Not Yet Reviewed") {
				return gvExtensionRequestNotReviewed;
			}
			else if (currentTab === "Reviewed") {
				return gvExtensionRequestReviewed;
			}
		}

		function OnBulkSearchButtonClicked(s, e) {
			var grid = GetGridBasedOnCurrentTab();

			searchType = selectedIndex;
			const plaintiffs = document.getElementById('pasteFilterTextArea').value?.split('\n');
			searchIds = plaintiffs.map(p => p.trim())

			if (!grid.InCallback())
				grid.PerformCallback();
		}

		function OnBulkSearchFilterValueChanged(s, e) {
			var grid = GetGridBasedOnCurrentTab();
			let plaintiffIdSearchTypeValue = 0;
			let ticketSearchTypeValue = 1;
			let lawFirmIdSearchTypeValue = 2;
			let label = document.getElementById("searchHelpText")
			document.getElementById('pasteFilterTextArea').value = "";

			//Reset grid
			selectedIndex = null;
			searchType = null;
			searchIds = null;
			if (!grid.InCallback())
				grid.PerformCallback();

			//Get New searchIndex value
			const searchValue = cbSearchFilter.GetValue();
			selectedIndex = searchValue

			if (searchValue === plaintiffIdSearchTypeValue) {
				btnSearch.SetVisible(true);
				tbPasteFilter.SetVisible(true);
				label.innerText = "Enter or paste the Plaintiff Numbers below to apply the filter.";
				return;
			}
			if (searchValue === ticketSearchTypeValue) {
				btnSearch.SetVisible(true);
				tbPasteFilter.SetVisible(true);
				label.innerText = "Enter or paste the Ticket Numbers below to apply the filter.";
				return;
			}

			if (searchValue === lawFirmIdSearchTypeValue) {
				btnSearch.SetVisible(true);
				tbPasteFilter.SetVisible(true);
				label.innerText = "Enter or paste the Law Firm Client ID below to apply the filter.";
				return;
			}

			btnSearch.SetVisible(false);
			label.innerText = "";
			tbPasteFilter.SetVisible(false);
		}

	</script>

	<h2>Plaintiff Extension Request</h2>


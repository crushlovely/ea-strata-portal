{% raw %}
<div class="contentPane">
        
        

<script type="text/javascript">
    var selectedOptions = [];
    var chkBoxes = [];
    var owBoxes = [];
    var statusBoxes = [];
    var statusCtrl = null;
    var reviewerUser = null;
    var enhId = null;
    var reviewStatus = null;
    var reviewComment = null;
    var overwrite = false;
    var fxParam = 0;
    var qCount = 0;
    var transCount = 0;

    function AddCheckedToList(checked, optionId)
    {
        if (checked == true)
        {
            selectedOptions.push(optionId);
        }
        else if(checked == false)
        {
            if(selectedOptions.includes(optionId))
            {
                selectedOptions.splice(selectedOptions.indexOf(optionId), 1);
            }
        }
        //in CSE declaration, enable A/I & OW
    }
    function AddToBulkQueue(enhanceId, rs)
    {
        SetEnhId(enhanceId);
        reviewStatus = rs;
        fxParam = 1;
        if (enhId == enhanceId)
        {
            if (AnyChecked()) {
                if (!cbpBulkClaimReviews.InCallback()) {
                    cbpBulkClaimReviews.PerformCallback();
                }
            }
        }
    }
    function SubmitBulkReview(s,e)
    {
        fxParam = 2;
        if (!cbpBulkClaimReviews.InCallback()) {
            cbpBulkClaimReviews.PerformCallback();
        }
    }
    function ClearQueue()
    {
        fxParam = 3;
        if (!cbpBulkClaimReviews.InCallback()) {
            cbpBulkClaimReviews.PerformCallback();
        }
    }
    function BulkTransition(s,e)
    {
        statusBoxes = BulkTransitionCBList.GetSelectedValues();
        fxParam = 4;
        if (!cbpBulkClaimReviews.InCallback()) {
            cbpBulkClaimReviews.PerformCallback();
        }
    }
    function OnBeginBulkReviewCallback(s,e)
    {
        e.customArgs["EnhId"] = enhId;
        e.customArgs["reviewStatus"] = reviewStatus;
        e.customArgs["reviewComment"] = reviewComment;
        e.customArgs["reviewer"] = reviewerUser;
        e.customArgs["overwrite"] = overwrite;
        e.customArgs["function"] = fxParam;
        if (fxParam == 4)
            e.customArgs["selected"] = statusBoxes;
        else
            e.customArgs["selected"] = selectedOptions;

        enhId = null;
        selectedOptions = [];
        reviewStatus = null;
        reviewComment = null;
        overwrite = false;
    }
    function OnEndBulkReviewCallback(s,e)
    {
        if(fxParam == 1)
        {
            qCount++;
            SetLabelText(qCount);
            gvBulkReview.CollapseAllDetailRows();
            SubmitClearButtonState();
        }
        else if(fxParam == 2) //submit bulk review queue
        {
            qCount = 0;
            SetLabelText(0);
            reviewerUser = null;
            SelectedReviewer.SetValue(null);
            gvBulkReview.CollapseAllDetailRows();
            SubmitClearButtonState();
        }
        else if (fxParam == 3) //clear bulk queue
        {
            qCount = 0;
            SetLabelText(0);
            SubmitClearButtonState();
        }
        else if(fxParam == 4) //bulk transition
        {
            SubmitClearButtonState();
            TransitionButtonLabelState(s,e);
        }
        fxParam = 0;
    }
    function ChkBoxState(s,e)
    {
        if (reviewerUser != null && chkBoxes != [])
        {
            for(var i = 0; i < chkBoxes.length; i++)
            {
                chkBoxes[i].SetEnabled(true);
            }
        }
    }
    function TransitionButtonLabelState(s,e)
    {
        $.ajax({
            cache: false,
            url: '/Admin/UpdateBulkReviewView',
            data: {
                transitionCount: transCount
            }, success: function(data){
                statusBoxes = [];
                transCount = data.tCount;
                BulkTransitionClaims.SetEnabled(transCount > 0 && statusBoxes != []);
                BulkTransitionCount.SetText("Claims to Transition: "+transCount);
                BulkTransitionCBList.SetEnabled(transCount > 0);
                statusCtrl.UnselectAll();
            },
            error: function(data){

            }
        });
    }
    function SubmitClearButtonState()
    {
        if(qCount > 0)
        {
            SubmitBulkReviews.SetEnabled(true);
            ClearBulkQueue.SetEnabled(true);
        }
        else
        {
            SubmitBulkReviews.SetEnabled(false);
            ClearBulkQueue.SetEnabled(false);
        }
    }
    function SetEnhId(enhanceId)
    {
        enhId = enhanceId;
    }
    function SetLabelText(count)
    {
        BulkQueueCount.SetText("Reviews in Queue: " + count);
    }
    function AnyChecked()
    {
        if (selectedOptions.length != 0 && reviewerUser != null)
            return true;
        else
            return false;
    }

</script>




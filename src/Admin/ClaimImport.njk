<script>
    function fileUploadCompleteEvent(s, e) {
        popLoading.Hide();

        //set DocumentReferenceId from callback
        document.getElementById('DocumentReferenceId').value = e.callbackData;

        if (e.callbackData != null && e.callbackData != undefined && e.callbackData != "") {

            //only callback if import processed
            if (!cbpClaimImportPartial.InCallback())
                cbpClaimImportPartial.PerformCallback();

            if (!gvClaimImportExceptions.InCallback())
                gvClaimImportExceptions.PerformCallback();

            if (!gvBulkClaimImportExceptions.InCallback())
                gvBulkClaimImportExceptions.PerformCallback();

            cbpClaimImportPartial.SetVisible(true);
            document.getElementById("exceptionsHeader").style.visibility = "visible"
            document.getElementById("bulkexceptionsHeader").style.visibility = "visible"
            gvClaimImportExceptions.SetVisible(true);
            gvBulkClaimImportExceptions.SetVisible(true);
        }
    }

    function OnBeginImportPartialCallback(s, e) {
        e.customArgs["documentReferenceId"] = document.getElementById('DocumentReferenceId').value;
    }

    function OnBeginExceptionGridCallback(s, e) {
        e.customArgs["documentReferenceId"] = document.getElementById('DocumentReferenceId').value;
        
    }

    function OnEndExceptionGridCallback(s, e) {
        //grid update command
        var command = e.command;

        //callback other panels to keep sync if update command
        if (command == "UPDATEEDIT") {
            if (!cbpClaimImportPartial.InCallback())
                cbpClaimImportPartial.PerformCallback();
            if (!gvBulkClaimImportExceptions.InCallback())
                gvBulkClaimImportExceptions.PerformCallback();
        }
    }
        

    function OnEndBulkExceptionGridCallback(s, e) {
        //grid update command
        var command = e.command;

        //callback other panels to keep sync if update command
        if (command == "UPDATEEDIT") {
            if (!cbpClaimImportPartial.InCallback())
                cbpClaimImportPartial.PerformCallback();
            if (!gvClaimImportExceptions.InCallback())
                gvClaimImportExceptions.PerformCallback();
        }
    }

    function OnBeginBulkExceptionGridCallback(s, e) {
        e.customArgs["documentReferenceId"] = document.getElementById('DocumentReferenceId').value;
    }

    function fileUploadStarted(s, e) {
        popLoading.Show();
    }
</script>


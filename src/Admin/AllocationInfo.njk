---
layout: layouts/base.njk
title: "Allocation Info"
---
{% raw %}
<div class="contentPane">
        <style>
          .fixed {
            position: fixed;
            top: 100px;
          }
          .fixed.adjust {
            top: -1.95rem !important;
          }

          .form-cell-no-caption {
            width: 0px;
            padding: 0px 0px 0px 0px;
            max-width: 0px;
          }
        </style>

        <script type="text/javascript">
          var panel;
          var origOffsetY;

          function DisplayHelpPop(s, e) {
            if (s.name == "imgSaveButtonHelp") {
              alert(
                "This button captures and saves the values for each respective field.",
              );
            } else if (s.name == "imgCalcButtonHelp") {
              alert(
                "Step 1 will calculate the total pool points and dollars per point for allocation calculations." +
                  'This information will flow to the Special master review screen, but will not display for claimants until the \n\"Step 2: Begin Claim Package Process\" button has been selected.' +
                  "\n\n" +
                  "This step will also capture the initial allocation points and dollars per claimant and will store these values in the database. These values can be reviewed via the special master review screen or via the Initial Allocation Breakdown administrative report. " +
                  "This will allow admin users to review allocation calculations prior to displaying them to the claimants.",
              );
            } else if (s.name == "imgBeginCPButtonHelp") {
              alert(
                "Step 2 will calculate the total pool points and dollars per point for allocation calculations, and will also push Review Complete: Eligible claims into the Eligible: Pending Claim Package Decision status. " +
                  "Please make sure all submitted claims are in Review Compete: Eligible or Ineligible status before starting this step." +
                  "\n\n" +
                  'When Step 2 is pressed, Step 1 will no longer regenerate the initial allocation history, therefore step 2 "locks in" the initial allocation history for claim packaging. ' +
                  "Button 2 can be clicked again however to recalculate initial allocation histories. This is the data that will be displayed to claimants so please minimize the number of times that step 2 is selected to prevent claimant confusion of changing initial allocation points and dollars." +
                  "\n\n" +
                  "These initial allocation values can be reviewed via the special master review screen or via the Initial Allocation Breakdown administrative report. This will allow admin users to review allocation calculations that are being displayed to the claimants.",
              );
            } else if (s.name == "imgUndoCPButtonHelp") {
              alert(
                'Undoing Step 2 will revert the flag on the system that allows for claim packaging to begin.  This will make it so that the Step 1 button will recalculate initial allocation again.  Additionally, all claims in the "Eligible: Pending Claim Package Decision" will be transitioned back to the "Review Complete: Eligible" status.',
              );
            } else if (s.name == "imgCalcFinalAllocButtonHelp") {
              alert(
                "Please note: selecting this button will disable both Step 1 and Step 2 buttons from being selected going forward." +
                  "\n\n" +
                  'Step 3 will recalculate the total pool points and dollars per point to achieve the final allocation values from all claim statuses. This information will again flow to the Special Master review screen, but values will not display for claimants until the "Step 4: Set Final Allocation Values" button has been selected.' +
                  "\n\n" +
                  "This step will also capture the final allocation points and dollars per claimant and will store these values in the database. These final values can be reviewed via the Special Master review screen or via the Final Allocation Breakdown administrative report. This will allow admin users to review final allocation values prior to displaying them to the claimants." +
                  "\n\n" +
                  'Claimants designated as "Excluded From Allocation" within the review screen will not be included in the final allocation values.',
              );
            } else if (s.name == "imgSetFinalAllocButtonHelp") {
              alert(
                "Please note: prior to selecting this button, users should ensure all claims have made an allocation decision and/or submitted the claim package and also does not have any pending appeals; all final allocation pools and values are set; and all Opt-Out claims are manually adjusted to account for allocation dollars excluded or rolled back to the defendant." +
                  "\n\n" +
                  "Step 4 will calculate the final total points and dollars per point for allocation calculations. This data will be displayed to claimants so please minimize the number of times that Step 4 is selected to prevent claimant confusion in regards to changing final allocation points and dollars." +
                  "\n\n" +
                  "Step 4 will also push Accepted: Review Complete or Declined: Opt-Out / Withdrawn claims into the Accepted: Allocation Finalized or Declined: Closed statuses, respectively." +
                  "\n\n" +
                  "Step 4 cannot be run unless all claims are in one of the following statuses: \n" +
                  "Accepted: Pending Claim Package Review, Accepted: In Claim Package Review, Accepted: Review Complete, \n" +
                  "Declined: Pending Claim Decision Review, Declined: In Claim Decision Review, Declined: Opt-Out/Withdrawn, \n" +
                  "Eligible: Pending Claim Package Decision, Accepted: Pending Claim Package Submission, \n" +
                  "Claim Package Review Pending: Incomplete Items, Claim Decision Review Pending: Incomplete Items, Review Complete: Ineligible, Not Submitted." +
                  "\n\n" +
                  'Step 4 also "locks in" the initial allocation history.' +
                  "\n\n" +
                  "Final allocation values can be reviewed via the Special Master review screen, the Final Allocation administrative report of on the claimant’s final allocation screen.",
              );
            } else if (s.name == "imgUndoSetFinalAllocButtonHelp") {
              alert(
                'Undoing Step 4 will revert the case status on the system to Final Allocation Calculation Start.  This will make it so that the Step 3 button will recalculate final allocation again.  Additionally, all claims in the "Accepted: Reported to QSF" or "Declined: Closed" will be transitioned back to the "Accepted: Review Complete" or "Declined: Opt-out/Withdrawn" status.',
              );
            }
          }
          function onScroll(e) {
            if (flAllocationInfo.GetHeight() > 1500) {
              window.pageYOffset + 97 >= origOffsetY
                ? panel.classList.add("fixed")
                : panel.classList.remove("fixed");
              window.pageYOffset + 97 >= 2495
                ? panel.classList.add("adjust")
                : panel.classList.remove("adjust");
            }
          }

          function controlPanelLoad(s, e) {
            panel = flAllocationControlPanel.mainElement;
            origOffsetY = panel.offsetTop;
          }

          function CalculateBalanceAmount() {
            var balance = SettlementAmountDollars.GetValue();
            balance -= PrimaryPoolDollars.GetValue();
            balance -= SecondaryPoolDollars.GetValue();
            balance -= ReserveAmountDollars.GetValue();
            BalanceAmountDollars.SetValue(balance);
          }

          document.addEventListener("scroll", onScroll);
        </script>

        <h2>Allocation Info</h2>

        <p>
          Use this screen to set the Injury Points values and the
          Enhancer/Detractor percentages. For the percentages, please enter the
          value in decimal format (i.e. 20% = 0.20, -50% = -0.50, etc).
        </p>


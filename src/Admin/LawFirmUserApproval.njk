<script type="text/javascript">
    var lawFirmStagingId;
    function CustomDetermineButtonClick(s, e) {
        var key = s.GetRowKey(e.visibleIndex);
        if (e.buttonID == 'btnDetermine') {
            //Show popup and callback panel inside to show data for approval
            lawFirmStagingId = key;
            pcLawFirmUserInfo.PerformCallback();
            pcLawFirmUserInfo.Show();
        }
    }

    function LawFirmUserInfoBeginCallback(s, e) {
        e.customArgs["lawFirmStagingId"] = lawFirmStagingId;
    }

    function LawFirmUserInfoEndCallback(s, e) {
        lawFirmStagingId = null;

        SetButtonsEnabled(true);
    }

    function SetButtonsEnabled(state) {
        btnApprove.SetEnabled(state);
        btnDeny.SetEnabled(state);
    }

    function BeginAvailableLawFirmsCallback(s, e) {
        e.customArgs["StartDate"] = deLawFirmApprovalStartDate.GetText();
        e.customArgs["EndDate"] = deLawFirmApprovalEndDate.GetText();
    }

    function BeginApprovedLawFirmsCallback(s, e) {
        e.customArgs["StartDate"] = deLawFirmApprovalStartDate.GetText();
        e.customArgs["EndDate"] = deLawFirmApprovalEndDate.GetText();
    }

    function BeginDeniedLawFirmsCallback(s, e) {
        e.customArgs["StartDate"] = deLawFirmApprovalStartDate.GetText();
        e.customArgs["EndDate"] = deLawFirmApprovalEndDate.GetText();
    }

    function OnLawFirmApprovalDateRangeChanged(s, e) {
        if (typeof gvAvailableLawFirms !== 'undefined' && !gvAvailableLawFirms.InCallback())
            gvAvailableLawFirms.PerformCallback();

        if (typeof gvApprovedLawFirms !== 'undefined' && !gvApprovedLawFirms.InCallback())
            gvApprovedLawFirms.PerformCallback();

        if (typeof gvDeniedLawFirms !== 'undefined' && !gvDeniedLawFirms.InCallback())
            gvDeniedLawFirms.PerformCallback();
    }
</script>


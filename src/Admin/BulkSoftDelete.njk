<script>
    let preventPaste = false
    const maxNumberOfPlaintiffNumbers = 500

    let textAreaDelete = document.getElementById('pasteFilterTextAreaBulkSoftDelete');
    
    textAreaDelete.addEventListener('paste', function (e) {
        if (preventPaste) {
            e.preventDefault();
        }
    });

    function updateLineNumbers() {
        const textArea = document.getElementById('pasteFilterTextAreaBulkSoftDelete');
        const lineNumbers = document.getElementById('lineNumbersBulkSoftDelete');

        let lineArray = textArea.value.split('\n')
        let lineCount = lineArray.length < 20 ? 20 : lineArray.length;

        if (lineCount > maxNumberOfPlaintiffNumbers) {
            textArea.value = lineArray.slice(0, 500).join('\n');
        }

        let lineAfterTruncateCount = textArea.value.split('\n').length < 20 ? 20 : textArea.value.split('\n').length;
        lineNumbers.innerHTML = '';

        for (let i = 1; i <= lineAfterTruncateCount; i++) {
            const lineNumber = document.createElement('span');
            lineNumber.textContent = i;
            lineNumbers.appendChild(lineNumber);
        }

        preventPaste = lineAfterTruncateCount >= maxNumberOfPlaintiffNumbers
        if (lineAfterTruncateCount > maxNumberOfPlaintiffNumbers) {
            btnSearch.SetEnabled(false);
            return;
        }
        btnSearch.SetEnabled(true);
    }

    function syncScroll() {
        const textArea = document.getElementById('pasteFilterTextAreaBulkSoftDelete');
        const lineNumbers = document.getElementById('lineNumbersBulkSoftDelete');
        lineNumbers.scrollTop = textArea.scrollTop;
    }

    // Initialize line numbers on page load
    updateLineNumbers();
</script>



<script>
    var factSheetNumbersForSoftDelete = []

    // General
    function ChangeTab(tabName, bulkOperationType) {
        const currentTabIndex = pcBulkOperationsWizard.activeTabIndex;
        pcBulkOperationsWizard.tabs[currentTabIndex].SetEnabled(false, true);

        const newTabIndex = pcBulkOperationsWizard.tabs.findIndex(t => t.name === tabName);
        pcBulkOperationsWizard.tabs[newTabIndex].SetEnabled(true, true);
        pcBulkOperationsWizard.SetActiveTabIndex(newTabIndex);
        if (tabName === "tabEntrySelection") {
            btnSearch.SetEnabled(true);
        } else if (tabName === "tabSelectionPreview") {
            const selectedEntryIds = factSheetNumbersForSoftDelete;
            if (!cbpBulkSoftDeleteSelectionPreview.InCallback()) {
                cbpBulkSoftDeleteSelectionPreview.PerformCallback({ factSheetNumbers: factSheetNumbersForSoftDelete });
            }
        } else if (tabName === "tabOperationComplete") {
            if (!cbpBulkSoftDeleteOperationComplete.InCallback()) {
                cbpBulkSoftDeleteOperationComplete.PerformCallback({ factSheetNumbers: factSheetNumbersForSoftDelete });
            }
        }

        window.scrollTo(0, 0);
    }

    function OnBulkSoftDeleteGridBeginCallback(s, e) {

        if (s.cpViewState === "SelectionPreview") {
            e.customArgs["factSheetNumbers"] = factSheetNumbersForSoftDelete;
        }
        else if (s.cpViewState === "OperationComplete") {
            e.customArgs["factSheetNumbers"] = factSheetNumbersForSoftDelete;
        }
    }

    function OnBulkSoftDeletePreviewSendButtonClicked(s, e) {
        factSheetNumbersForSoftDelete = document.getElementById('pasteFilterTextAreaBulkSoftDelete').value?.split('\n').map(p => p.trim()).filter(name => name?.length > 0);

        s.SetEnabled(false);
        ChangeTab("tabSelectionPreview");
    }

    function OnBulkSoftDeleteBackSelectionPreviewButtonClicked(s, e) {
        ChangeTab("tabEntrySelection");
    }

    function OnBulkSoftDeleteBackExecuteOperationButtonClicked(s, e) {
        pcBulkSoftDeleteSelectionPreviewApproval.Show();
    }

    function OnBulkSoftDeleteCancelApprovalButtonClicked(s, e) {
        pcBulkSoftDeleteSelectionPreviewApproval.Hide();
    }

    function ExecuteBulkSoftDeleteOperation(url) {
        pcBulkSoftDeleteSelectionPreviewApproval.Hide();
        pcOperationProcessing.Show();

        var token = $('input[name="__RequestVerificationToken"]').val();

        $.ajax({
            cache: false,
            method: 'POST',
            url: url,
            data: {
                __RequestVerificationToken: token,
                factSheetNumbers: factSheetNumbersForSoftDelete
            },
            success: function (data) {
                if (data.Success === false) {
                    window.location.reload();
                    return;
                }

                ChangeTab("tabOperationComplete");
            },
            error: function (data) {
                window.location.reload();
                showFlashIfPopulated();
            },
            complete: function () {
                pcOperationProcessing.Hide();
            }
        })
    }

    // 'Operation Complete' tab
    function OnHomeButtonClicked(url) {
        window.location.href = url;
    }

    function OnBackToBulkSoftDeleteSelectionButtonClicked(s, e) {
        window.location.reload();
    }
</script>


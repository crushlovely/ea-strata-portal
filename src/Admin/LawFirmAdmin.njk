<script type="text/javascript">
    var lawFirmId;

    function OpenNewFirmInfo(s, e)
    {
        gvLawFirms.AddNewRow();
    }

    function OpenLawFirmDocuments(s, e, lId) {
            lawFirmId = lId;
            pcLawFirmDocuments.PerformCallback();
            pcLawFirmDocuments.Show();
    }

    function LawFirmDocumentsBeginCallback(s, e) {
        e.customArgs["lawFirmId"] = lawFirmId;
    }

    function LawFirmDocumentsEndCallback(s, e) {
        lawFirmId = null;
    }

    function fileUploadCompleteEvent(s, e, lId) {
        lawFirmId = lId;
        cbLawFirmDocType.SetValue(null);
        LawFirmDocUpload.SetEnabled(false);
        //if (!pcLawFirmDocuments.InCallback) 
            pcLawFirmDocuments.PerformCallback();
    }

    function EnableUploadControl(s, e) {
        LawFirmDocUpload.SetEnabled(cbLawFirmDocType.GetValue() != null);
    }

    function deleteLawFirmDoc(s, e, docId, lId) {
        if (confirm('Are you sure you wish to delete this law firm document?')) {
            $.ajax({
                cache: false,
                traditional: true,
                url: '/Admin/DeleteLawFirmDoc',
                data: {
                    docId: docId
                },
                success: function (data) {
                    fileUploadCompleteEvent(s, e, lId);
                    showFlashIfPopulated();
                },
                error: function (data) {
                    showFlashIfPopulated();
                }
            });
        }
    }
</script>


<div class="d-grid grid-cols-1 gap-block">





	<script type="text/javascript">
		function getEnhancementTypeID(s, e, enhID) {
			enhancementId = enhID;
			e.customArgs["EnhancementId"] = enhancementId;
			gvEnhOptions.PerformCallback();
		}
		function BeginDetailRowCallback(s, e) {
			e.customArgs["EnhancementId"] = enhancementId;
		}
		function ClearClaimData(s, e) {
			if (confirm("This will permanently delete all Claims and records relating to Claims. This action cannot be undone. Are you sure you wish to continue?")) {
				if (!cbpClearClaimData.InCallback())
					cbpClearClaimData.PerformCallback();
			}
		}
		function OnBeginClearDataCallback(s, e) {
			e.customArgs["clear"] = true;
		}
		function OnEndClearDataCallback(s, e) {
			gvInjuryTypes.Refresh();
			gvEnhancementQuestions.Refresh();
		}
	</script>




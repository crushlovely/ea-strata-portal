<script>
    function fileDocImportUploadCompleteEvent(s, e) {
        popDocumentImportLoading.Hide();

        if (e.callbackData != null && e.callbackData != undefined && e.callbackData != "") {

            //only callback if import processed
            if (!cbPlaintiffDocumentImportPartial.InCallback())
                cbPlaintiffDocumentImportPartial.PerformCallback();

            cbPlaintiffDocumentImportPartial.SetVisible(true);
        }
    }

    function OnBeginDocumentImportPartialCallback(s, e) {
        //e.customArgs["documentReferenceId"] = document.getElementById('DocumentReferenceId').value;
    }

    function fileDocImportUploadStarted(s, e) {
        popDocumentImportLoading.Show();
    }
</script>

<script>
    const MAX_IMPORT_RECORD_COUNT = 50_000;
    const PROCESS_STATUS_FAILED = 0;
    const PROCESS_STATUS_NEEDS_APPROVAL = 1;
    const PROCESS_STATUS_SUCCESS = 2;

    let selectedImportTypeId = 15;

    // File Uploading Callbacks
    function OnFileUploadStart(s, e) {
        pcScanLoadingModal.Show();
    }

    function OnFileUploadComplete(s, e) {
        pcScanLoadingModal.Hide();

        // Get summary from upload callback
        const summary = JSON.parse(e.callbackData);
        console.log(summary);

        // Show import error modal
        if (summary.RecordCount > MAX_IMPORT_RECORD_COUNT) {
            // Show error pop-up for import
            if (!pcImportErrorModal.InCallback())
                pcImportErrorModal.PerformCallback();

            return;
        }

        // Show confirmation pop-up for import
        if (!pcImportConfirmationModal.InCallback())
            pcImportConfirmationModal.PerformCallback();
    }
    // Modal Popup Callbacks
    function OnEndImportErrorModalCallback(s, e) {
        s.Show();
    }

    function OnEndImportConfirmationModalCallback(s, e) {
        s.Show();
    }

    function OnEndImportProcessingDetailsModalCallback(s, e) {
        pcProcessLoadingModal.Hide();
        s.Show();
    }

    function OnEndImportSummaryModalCallback(s, e) {
        pcProcessLoadingModal.Hide();
        s.Show();
    }

    function OnImportCancelButtonClicked(s, e) {
        pcImportProcessingDetailsModal.Hide();
    }

    async function OnImportProceedButtonClicked(s, e) {
        pcImportProcessingDetailsModal.Hide();

        try {
            pcProcessLoadingModal.Show();

            const response = await fetch(`SaveProcessedRecords?importTypeId=${selectedImportTypeId}`, {
                method: "POST"
            });

            if (!response.ok) {
                alert("An error occurred while trying to process your import. Please try again.");
                pcProcessLoadingModal.Hide();
                return;
            }

            const result = await response.json();
            if (!result.Success) {
                alert("An error occurred while trying to process your import. Please try again.");
                pcProcessLoadingModal.Hide();
                return;
            }

            // Display post-import summary
            if (!pcImportSummaryModal.InCallback())
                pcImportSummaryModal.PerformCallback();
        }
        catch (error) {
            alert("An error occurred while trying to process your import. Please try again.");

            console.error(error);
            pcProcessLoadingModal.Hide();
        }
    }

    function OnImportNoButtonClicked(s, e) {
        pcImportConfirmationModal.Hide();
    }

    async function OnImportYesButtonClicked(s, e) {
        pcImportConfirmationModal.Hide();

        try {
            pcProcessLoadingModal.Show();

            const response = await fetch(`ProcessUploadedFile?importTypeId=${selectedImportTypeId}`, {
                method: "POST"
            });

            if (!response.ok) {
                alert("An error occurred while trying to process your import. Please try again.");
                pcProcessLoadingModal.Hide();
                return;
            }

            const result = await response.json();
            if (!result.Success) {
                alert("An error occurred while trying to process your import. Please try again.");
                pcProcessLoadingModal.Hide();
                return;
            }

            const data = result.Data;
            if (data.ProcessStatus === PROCESS_STATUS_NEEDS_APPROVAL) {
                // Display warnings on modal
                if (!pcImportProcessingDetailsModal.InCallback())
                    pcImportProcessingDetailsModal.PerformCallback();

            } else {
                // Display post-import summary
                if (!pcImportSummaryModal.InCallback())
                    pcImportSummaryModal.PerformCallback();
            }
        }
        catch (error) {
            alert("An error occurred while trying to process your import. Please try again.");

            console.error(error);
            pcProcessLoadingModal.Hide();
        }
    }
</script>

<script>
    const MEDICAL_RECORD_DOC_TYPE_ID = 7;
    const BULK_MEDICAL_RECORD_MAX_FILE_SIZE = 524288000;
    const BULK_DEFAULT_MAX_FILE_SIZE = 314572800;

    let plaintiffDocumentImportHandledInvalidFileNames = [];

    function getPlaintiffDocumentImportDocTypeId(fileName) {
        const parts = fileName.split('_');
        if (parts.length !== 3)
            return null;

        const docTypeId = parseInt(parts[1], 10);
        return isNaN(docTypeId) ? null : docTypeId;
    }

    function getPlaintiffDocumentImportMaxAllowedSize(fileName) {
        const docTypeId = getPlaintiffDocumentImportDocTypeId(fileName);

        return docTypeId === MEDICAL_RECORD_DOC_TYPE_ID ? BULK_MEDICAL_RECORD_MAX_FILE_SIZE : BULK_DEFAULT_MAX_FILE_SIZE;
    }

    function getInvalidFileDisplayName(file) {
        if (!file)
            return "";

        if (typeof file === "string")
            return file;

        if (file.name)
            return file.name;

        if (file.fileName)
            return file.fileName;

        if (file.inputFile && file.inputFile.name)
            return file.inputFile.name;

        if (file.text)
            return file.text;

        return "";
    }

    function buildBulkDocumentImportMultiFileMessage(invalidFiles) {
        const invalidFileNames = invalidFiles
            .map(getInvalidFileDisplayName)
            .filter(name => name && name.trim() !== "");

        return "Attention! " + invalidFileNames.length + " files are invalid and will not be uploaded. " + "Possible reasons are: they exceed the allowed file size per document (500MB for Medical Records and 300MB for all other document types), " + "their extensions are not allowed, or their filenames contain invalid characters. These files have been removed from the selection:\n\n" + invalidFileNames.join("\n");
    }

    function showBulkDocumentImportSingleFileMessage() {
        alert("You have exceeded the maximum file size of 500MB for Medical Records or 300MB for all other document types.");
    }

    function onPlaintiffDocumentImportTextChanged(s, e) {
        const selectedFiles = s.GetSelectedFiles();
        if (!selectedFiles || !selectedFiles.length)
            return;

        const invalidFiles = [];

        for (let i = selectedFiles.length - 1; i >= 0; i--) {
            const file = selectedFiles[i];
            const maxAllowedSize = getPlaintiffDocumentImportMaxAllowedSize(file.name);

            if (file.size > maxAllowedSize) {
                invalidFiles.push({
                    index: i,
                    name: file.name
                });
            }
        }

        if (!invalidFiles.length) {
            plaintiffDocumentImportHandledInvalidFileNames = [];
            return;
        }

        for (let i = 0; i < invalidFiles.length; i++) {
            s.RemoveFileFromSelection(invalidFiles[i].index);
        }

        const invalidFileNames = invalidFiles.map(f => f.name).reverse();
        plaintiffDocumentImportHandledInvalidFileNames = invalidFileNames.slice();

        if (invalidFileNames.length === 1 && selectedFiles.length === 1) {
            showBulkDocumentImportSingleFileMessage();
            return;
        }

        alert(buildBulkDocumentImportMultiFileMessage(invalidFileNames));
    }

    function onPlaintiffDocumentImportValidationErrorOccurred(s, e) {
        if (!e.invalidFiles || !e.invalidFiles.length)
            return;

        e.showAlert = false;

        const invalidFileNames = e.invalidFiles
            .map(getInvalidFileDisplayName)
            .filter(name => name && name.trim() !== "");

        const remainingInvalidFileNames = invalidFileNames.filter(name =>
            plaintiffDocumentImportHandledInvalidFileNames.indexOf(name) === -1
        );

        plaintiffDocumentImportHandledInvalidFileNames = [];

        if (!remainingInvalidFileNames.length)
            return;

        if (remainingInvalidFileNames.length === 1) {
            showBulkDocumentImportSingleFileMessage();
            return;
        }

        alert(buildBulkDocumentImportMultiFileMessage(remainingInvalidFileNames));
    }
</script>

<h2>Plaintiff Document Import</h2>
<p><b>Use this section to bulk import plaintiff documents.</b></p><p>

</p><p>Use the uploader below to select 1 or more documents to upload for your plaintiffs.  You can select multiple documents by holding down the CTRL or SHIFT key and clicking multiple documents in the popup when using the uploader.</p>

<p>
    The naming convention of the documents <b>must</b> follow the format below:<br>
    CLAIMNUMBER_DOCUMENTTYPEID_FILENAME.EXTENSION (E.g. XYZ0001_19_JohnDoePlaintiffFactSheet.pdf) <br>
    <br>
    To see the list of document type IDs, click <a href="#" onclick="window.open('/Import/PlaintiffDocTypes', '_blank')">here</a>.
</p>


{% raw %}
<div class="d-grid grid-cols-1 gap-block">
        
        

<script type="text/javascript">

    function ImportLogSelectionCallback(s, e) {
        const selectedImportId = s.GetRowKey(e.visibleIndex);

        exportImportLog(`ExportImportLogRecords?importLogId=${selectedImportId}`);
    }

    function exportImportLog(url) {
        $.ajax({
            type: "GET",
            url: url,
            xhrFields: {
                responseType: 'blob'
            },
            success: function (data) {
                const a = document.createElement('a');
                const url = window.URL.createObjectURL(data);
                a.href = url;
                a.download = `Import_Log_Export_${new Date().toISOString()}.xlsx`;
                a.click();
                window.URL.revokeObjectURL(url);
            },
            error: function (error) {
                console.error(error);
                alert(error);
            }
        });
    }

</script>


{% raw %}
<div class="d-grid grid-cols-1 gap-block">
        
        

<script type="text/javascript">

    const MAX_IMPORT_RECORD_COUNT = 50_000;
    const PROCESS_STATUS_FAILED = 0;
    const PROCESS_STATUS_NEEDS_APPROVAL = 1;
    const PROCESS_STATUS_SUCCESS = 2;

    let selectedImporttypeId = null;

    // File Uploading Callbacks
    function OnFileUploadStart(s, e) {
        pcScanLoadingModal.Show();
    }

    function OnFileUploadComplete(s, e) {
        pcScanLoadingModal.Hide();

        // Get summary from upload callback
        const summary = JSON.parse(e.callbackData);
        console.log(summary);

        // Show import error modal
        if (summary.RecordCount > MAX_IMPORT_RECORD_COUNT) {
            // Show error pop-up for import
            if (!pcImportErrorModal.InCallback())
                pcImportErrorModal.PerformCallback();

            return;
        }

        // Show confirmation pop-up for import
        if (!pcImportConfirmationModal.InCallback())
            pcImportConfirmationModal.PerformCallback();
    }

    // Modal Popup Callbacks
    function OnEndImportErrorModalCallback(s, e) {
        s.Show();
    }

    function OnEndImportConfirmationModalCallback(s, e) {
        s.Show();
    }

    function OnEndImportProcessingDetailsModalCallback(s, e) {
        pcProcessLoadingModal.Hide();
        s.Show();
    }

    function OnEndImportSummaryModalCallback(s, e) {
        pcProcessLoadingModal.Hide();
        s.Show();
    }

    function OnImportCancelButtonClicked(s, e) {
        pcImportProcessingDetailsModal.Hide();
    }

    async function OnImportProceedButtonClicked(s, e) {
        pcImportProcessingDetailsModal.Hide();

        try {
            pcProcessLoadingModal.Show();

            const response = await fetch(`SaveProcessedRecords?importTypeId=${selectedImporttypeId}`, {
                method: "POST"
            });

            if (!response.ok) {
                alert("An error occurred while trying to process your import. Please try again.");
                pcProcessLoadingModal.Hide();
                return;
            }

            const result = await response.json();
            if (!result.Success) {
                alert("An error occurred while trying to process your import. Please try again.");
                pcProcessLoadingModal.Hide();
                return;
            }

            // Display post-import summary
            if (!pcImportSummaryModal.InCallback())
                pcImportSummaryModal.PerformCallback();
        }
        catch (error) {
            alert("An error occurred while trying to process your import. Please try again.");

            console.error(error);
            pcProcessLoadingModal.Hide();
        }
    }

    function OnImportNoButtonClicked(s, e) {
        pcImportConfirmationModal.Hide();
    }

    async function OnImportYesButtonClicked(s, e) {
        pcImportConfirmationModal.Hide();

        try {
            pcProcessLoadingModal.Show();

            const response = await fetch(`ProcessUploadedFile?importTypeId=${selectedImporttypeId}`, {
                method: "POST"
            });

            if (!response.ok) {
                alert("An error occurred while trying to process your import. Please try again.");
                pcProcessLoadingModal.Hide();
                return;
            }

            const result = await response.json();
            if (!result.Success) {
                alert("An error occurred while trying to process your import. Please try again.");
                pcProcessLoadingModal.Hide();
                return;
            }

            const data = result.Data;
            if (data.ProcessStatus === PROCESS_STATUS_NEEDS_APPROVAL) {
                // Display warnings on modal
                if (!pcImportProcessingDetailsModal.InCallback())
                    pcImportProcessingDetailsModal.PerformCallback();

            } else {
                // Display post-import summary
                if (!pcImportSummaryModal.InCallback())
                    pcImportSummaryModal.PerformCallback();
            }
        }
        catch (error) {
            alert("An error occurred while trying to process your import. Please try again.");

            console.error(error);
            pcProcessLoadingModal.Hide();
        }
    }

    function MoveToElement(elementId) {
        const anchor = document.createElement("a");
        anchor.href = `#${elementId}`;
        document.body.appendChild(anchor);
        anchor.click();

        document.body.removeChild(anchor);
    }

    function StartImport(importTypeId) {
        // Set the selected import type id
        selectedImporttypeId = importTypeId;

        // Show the upload control
        const visibleIndex = gvImportTemplates.keys.findIndex(id => id == importTypeId);
        gvImportTemplates.GetRowValues(visibleIndex, "ImportName", (importName) => {
            lbFileSelection.SetText(`Select file to import ${importName}.`);
            ucFileSelection.SetEnabled(true);
            flImportSelect.SetVisible(true);

            MoveToElement("lbFileSelection");
        });
    }

</script>

<div class="mt-2">

    <h2>Plaintiff Details Bulk Import</h2>
    <br>
    <p>
        This import tool will help you import data in bulk&nbsp;for Plaintiff Profile Forms and Plaintiff Fact Sheets.&nbsp;These imports require the Plaintiff(s)
        to already be registered in the portal. Each import template has an instructions tab that serves as a guide. To perform an import, download the
        respective template, complete the template with all required data fields, click the 'Start Import' button, and confirm that you are importing the
        correct template. Allow a few moments for the portal to properly import the file.
    </p>


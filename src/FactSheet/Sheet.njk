          <script type="text/javascript">
            let factSheetId = 10;
            let currentView = null;
            let isInReview = 'False';
            let isFormEditable = 'True';
            let canEditPFS = 'True';
            let canEditPlaintiffInfo = 'True'
            let canEditCMO37Noncompliance3 = 'False'
            let canEditCMO37Noncompliance4 = 'False'
            let canEditCMO37Noncompliance2_2 = 'False'
            let canEditCMO37Noncompliance2_3 = 'False'
            let isEditing = false;
            let openGrids = [];

            let waId = 1;
            let wdId = 2;
            let adId = 3;
            let adDId = 4;
            let tgId = 5;
            let pdId = 6;
            let mpId = 7;
            let exId = 15;
            let yesOption = "Yes.";
            let canFullEditWaterAddressTable = 'True'



            var SaveResult = Object.freeze({
              OK: 'OK',
              CANCEL: 'Cancel'
            });

            function SetDefaultSection() {
              //For now, we can just call change section since the default selection is the 1st tab.
              //If in the future we have a need to load a different view first, we can manage that here
              currentView = '_PlaintiffInformation'; //TODO: Update this if needed
              NavBarPFS.SetSelectedItem(NavBarPFS.GetItemByName(currentView))
            }

            //Function used on grids to flag if the page is in edit mode.  We want to warn the user when they try to leave a page
            //in which they have unsaved data in a grid editor

            function SetEditMode(source) {
              let editState = source.editState;
              if (editState != 0) {
                if (!openGrids.some(og => og.uniqueID == source.uniqueID)) openGrids.push({ uniqueID: source.uniqueID, friendlyUserName: source.cpUserFriendlyName });
                isEditing = true;
              } else {
                openGrids = openGrids.filter(og => og.uniqueID !== source.uniqueID);
                if (openGrids.length == 0) {
                  isEditing = false;
                }
              }
            }

            function ChangeSection(s, e) {
              if (CanEdit()) {
                var goForward = true;
                if (isEditing)
                  goForward = confirm('Warning: Your data entry progress will not be saved unless all required fields are completed.  Click cancel to return to the page you are working on.  Click OK to continue to another page.');
                if (goForward) {
                  isEditing = false;
                  openGrids = [];
                  if (SavePFSSection(true)) {
                    ChangePFSSection(e.item.name);
                    return;
                  }
                }
              }
              else {
                ChangePFSSection(e.item.name);
              }
              NavBarPFS.SetSelectedItem(NavBarPFS.GetItemByName(currentView));
            }

            // Function used by Next button to validate and save current section, then go to the designated next section
            function GoToNextSection(nextViewName) {
              if (CanEdit()) {
                var goForward = true;
                if (isEditing)
                  goForward = confirm('Warning: Your data entry progress will not be saved unless all required fields are completed.  Click cancel to return to the page you are working on.  Click OK to continue to another page.');
                if (goForward) {
                  isEditing = false;
                  openGrids = [];
                  if (SavePFSSection(true)) {
                    ChangePFSSection(nextViewName);
                    return;
                  }
                }
              }
              else {
                ChangePFSSection(nextViewName);
              }
              NavBarPFS.SetSelectedItem(NavBarPFS.GetItemByName(currentView));
            }

            // Validates the current section's form data using the section's own IsPageValid function
            function IsValidPFSSection() {
              if (typeof IsPageValid === "function")
                return IsPageValid();
              return true;
            }

            function CanEdit(docUpload) {
              if (currentView == '_PlaintiffInformation') {
                return canEditPlaintiffInfo == 'True';
              }
              else {
                let exposureViews = ['_PlaintiffProfileExposureA', '_PFSPlaintiffFactSheetExposureA', '_PlaintiffProfileExposureB', '_PFSPlaintiffFactSheetExposureB', '_PlaintiffProfileExposureC', '_PFSPlaintiffFactSheetExposureC', '_PFSPlaintiffFactSheetExposureD'];

                let isFormFullEditable = (isFormEditable == 'True' || docUpload) && canEditPFS == 'True';
                let nonCompliance3Editable = canEditCMO37Noncompliance3 == 'True' && (currentView == '_PlaintiffProfilePersonalInjuries' || currentView == '_PFSPlaintiffFactSheetPersonalInjuries');
                let nonCompliance4Editable = canEditCMO37Noncompliance4 == 'True' && (currentView == '_PlaintiffProfilePersonalInjuries' || currentView == '_PFSPlaintiffFactSheetPersonalInjuries');
                let nonCompliance2_2Editable = canEditCMO37Noncompliance2_2 == 'True' && (exposureViews.includes(currentView));
                let nonCompliance2_3Editable = canEditCMO37Noncompliance2_3 == 'True';
                let isCurrentViewEditableByCMO37 = nonCompliance3Editable || nonCompliance4Editable || nonCompliance2_2Editable || nonCompliance2_3Editable;
                return isFormFullEditable || isCurrentViewEditableByCMO37;
              }
            }

            // Saves the current section's form data using the section's own SubmitPage function
            function SavePFSSection(tabChange = false, docUpload = false) {
              if (CanEdit(docUpload)) {
                if (typeof SubmitPage === "function") {
                  let targetUrl = '';
                  // safe to use the function
                  switch (currentView) {
                    case '_PlaintiffInformation': targetUrl = '/AFFF/SavePlaintiffInformation'; break;
                    case '_PreviouslyServedFactSheet': targetUrl = '/AFFF/SavePreviouslyServedFactSheet'; break;
                    case '_RepresentativeInformation': targetUrl = '/AFFF/SaveRepresentativeInformation'; break;
                    case '_PlaintiffProfileForm': targetUrl = '/AFFF/SavePlaintiffProfileForm'; break;
                    case '_PlaintiffProfileExposureA': targetUrl = '/AFFF/SavePlaintiffProfileExposureA'; break;
                    case '_PlaintiffProfileExposureB': targetUrl = '/AFFF/SavePlaintiffProfileExposureB'; break;
                    case '_PlaintiffProfileExposureC': targetUrl = '/AFFF/SavePlaintiffProfileExposureC'; break;
                    case '_PlaintiffProfilePersonalInjuries': targetUrl = '/AFFF/SavePlaintiffProfilePersonalInjuries'; break;
                    default: return true;
                  }

                  if (docUpload && isFormEditable == 'True') {
                    return false
                  }
                  if (typeof ConfirmRadioSwitchResponse === "function" && !ConfirmRadioSwitchResponse()) {
                    return false;
                  }
                  if (targetUrl != '') {
                    let isSaveButton = (!tabChange && !docUpload)
                    var result = SubmitPage(targetUrl, factSheetId, isSaveButton);
                    if (result === SaveResult.CANCEL) return false;
                    return true;
                  }
                }
              }
              return true
            }


            // Loads the designated section's partial view and sets the nav bar selected item and current view
            function ChangePFSSection(viewName) {
              if (viewName == "_ClaimantInformation") {
                window.location.href = "/Claim/ClaimForm/10";
              }
              else {
                $.ajax({
                  url: '/FactSheet/OpenFactSheetPanel',
                  type: 'POST',
                  async: false,
                  data: {
                    ViewName: viewName,
                    FactSheetId: factSheetId
                  },
                  success: function (result) {
                    currentView = viewName;
                    $('#mainForm').html(result);
                    //This callback is for the header review bar.  It is technically not following the full generic convention because we have to add it to the case specific header bar's tab change...
                    if (isInReview == 'True' && true) {
                      cbpReviewHeader.PerformCallback();
                    }
                    NavBarPFS.SetSelectedItem(NavBarPFS.GetItemByName(currentView));
                    window.scroll({
                      top: 0,
                      left: 0,
                      behavior: 'instant',
                    })
                  },
                  error: function (result) {
                    // Do something?
                  }
                });
              }
            }

            function ArrayToString(items) {
              if (items.length === 0) {
                return '';
              } else if (items.length === 1) {
                return items[0];
              } else if (items.length === 2) {
                return items.join(' and ');
              } else {
                return items.slice(0, -1).join(', ') + ', and ' + items[items.length - 1];
              }
            }

            function CallGridCallback(grid) {
              //if (!grid.InCallback())
              grid.PerformCallback();
            }
            function DoesGridHaveConfirmMessageFlagOrEntry(grid) {
              return (typeof grid.confirmMessageFlag == 'undefined' || grid.confirmMessageFlag != true) && grid.keys.length > 0
            }

            function DisplayLCNHelpPop(s, e) {
              if (s.name == "lawsuitCaseNumHelp")
                DisplayHelpPopup('Please input the Case Number in the following format: &#39;2:##-cv-#####-RMG&#39;. EX: &#39;2:21-cv-12345-RMG&#39;. If you are awaiting a Case Number, please enter the following: 2:00-cv-00000-RMG. This format is required for submission.');
            }

            function DisplayDODHelpPop(s, e) {
              if (s.name == "dateOfDischargeHelp") {
                DisplayHelpPopup('Please enter the date of discharge as mm/dd/yyyy. If only the month and year of discharge is known, enter the date as the first day of the month of discharge (ex: June 2024 - 06/01/2024). If only the year of discharge is known, enter the date as the first day of the first month of the year of discharge (ex: 2024 - 01/01/2024).');
              }
            }

            $(document).ready(() => {
              SetDefaultSection();
            });

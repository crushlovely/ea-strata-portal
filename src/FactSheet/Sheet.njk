  <script type="text/javascript">
    function SubmitReturnToPlaintiff(targetUrl, factSheetId) {
      btnSubmitReturnToPlaintiff.SetEnabled(false);
      $.ajax({
        cache: false,
        url: targetUrl,
        data: {
          FactSheetId: factSheetId,
        }, success: function (data) {
          showFlashIfPopulated();
          window.location.href = '/FactSheet/PFS/484f32fe-1618-4c04-9931-fe72a97af7ac';
        },
        error: function (data) {
          showFlashIfPopulated();
          // Show error message?
        },
        complete: function () {
          btnSubmitReturnToPlaintiff.SetEnabled(true);
        }
      });
    }
  </script>

  <script type="text/javascript">
    function SubmitAmendment(targetUrl, factSheetId) {
      btnSubmitReasonForAmendment.SetEnabled(false);
      var isValid = ASPxClientEdit.ValidateGroup('ReasonForAmendmentValidation');
      if (isValid) {
        $.ajax({
          cache: false,
          url: targetUrl,
          data: {
            FactSheetId: factSheetId,
            ReasonForAmendment: ReasonForAmendment.GetValue()

          }, success: function (data) {
            showFlashIfPopulated();
            if (data.IsSuccess) {
              window.location.href = '/FactSheet/PFS/484f32fe-1618-4c04-9931-fe72a97af7ac';
            }
          },
          error: function (data) {
            showFlashIfPopulated();
            // Show error message?
          },
          complete: function () {
            btnSubmitReasonForAmendment.SetEnabled(true);
          }
        });
      }
      else {
        btnSubmitReasonForAmendment.SetEnabled(true);
      }
    }
    function ShowReasonForAmendment(isReviewComplete) {
      if (isReviewComplete) {
        pcWarningForAlreadyComplete.Show();
      }
      else {
        pcReasonForAmendment.Show();
      }
    }
  </script>


<script type="text/javascript">
    function CustomEmailButtonClick(s, e) {
        if (confirm('Would you like to send the user a verification email?'))
        {
            var key = s.GetRowKey(e.visibleIndex);
            if (e.buttonID == 'btnSendEmail') {
                var url = '/Security/SendVerificationEmail' + '/' + key;
                window.location.href = url;
            }
        }
    }

    function ShowSendEmailCheckBox(s, e) {
        var key = s.GetRowKey(e.visibleIndex);

    }

    function OpenNewUserInfo(s, e) {
        gvUsers.AddNewRow();
    }

    var showPlaintiffs = false;

    function onPlaintiffShowCheck(s, e) {
        showPlaintiffs = s.GetChecked();
        $.ajax({
            url: '/Security/gvUsersPartial',
            type: 'GET',
            data: { showPlaintiffs: showPlaintiffs },
            success: function (result) {
                $("#gridViewContainer").html(result); // Update grid content
            }
        });
    }

    function ongvUsersBeginCallback(s, e) {
        e.customArgs["showPlaintiffs"] = showPlaintiffs; // Pass checkbox state on every callback
    }

    function CustomResetPasswordButtonClick(email, userId) {
        if (confirm('Do you want to send a reset password email to ' + email + '?'))
        {
            $.ajax({
                url: '/Security/SendPasswordResetEmail',
                type: 'POST',
                data: { userId: userId },
                success: function (result) {
                    showFlashIfPopulated();
                }
            });
        }
    }
</script>


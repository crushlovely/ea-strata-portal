<script type="text/javascript">
    var selectedUserRole = null;
    function UserRoleSelectionChanged(s, e) {
        cbpRolePermEdit.SetVisible(true);
        btnSaveUserRole.SetVisible(true);
        btnCopyUserRole.SetVisible(true);
        btnDeleteUserRole.SetVisible(true);
        selectedUserRole = s.GetSelectedValues();
        if (!cbpRolePermEdit.InCallback())
            cbpRolePermEdit.PerformCallback();
    }

    function NewUserRoleClick(s, e) {
        cbpRolePermEdit.SetVisible(true);
        btnSaveUserRole.SetVisible(true);
        btnCopyUserRole.SetVisible(false);
        btnDeleteUserRole.SetVisible(false);
        selectedUserRole = 0; //Pass 0 to indicate to the callback function new user role
        if (!cbpRolePermEdit.InCallback())
            cbpRolePermEdit.PerformCallback();
    }

    function OnBeginRolePermEditCallback(s, e) {
        e.customArgs["selectedUserRole"] = selectedUserRole;
        selectedUserRole = null;
    }

    function OnEndRolePermEditCallback(s, e) {
        //Permissions_Account.SelectAll();
        if (selectedUserRole != null) {
            cbpRolePermEdit.PerformCallback();
        }
    }

    //Prompt user to save changes before creating new role to prevent lost edits
    function NewUserCheckIfSavedUpdates(s, e) {
        //Don't prompt if no edits could have been made: after initial page load
        if (btnSaveUserRole.GetVisible() === true) {
            if (confirm('Please make sure you save changes made to user role before creating a new user role. Continuing will delete all unsaved changes. Do you wish to continue?')) {
                NewUserRoleClick();
            }
        }
        else {
            NewUserRoleClick();
        }
    }

</script>

